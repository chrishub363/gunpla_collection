<!DOCTYPE html>
<html class="h-full">
  <head>
    <title><%= content_for(:title) || "Gunpla Collection" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="Gunpla Collection">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= yield :head %>
    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="h-full bg-[#1a1625] text-[#f0e6ff] antialiased">

    <%# Top navigation bar %>
    <header class="sticky top-0 z-50 bg-[#1e1a2e] border-b border-[#2d2640] px-6 py-3">
      <div class="max-w-7xl mx-auto flex items-center gap-4">

        <%# Logo / site name %>
        <a href="<%= root_path %>" class="text-[#e879a0] font-bold text-xl tracking-tight shrink-0">
          Gunpla Collection
        </a>

        <%# Search bar %>
        <%= form_with url: root_path, method: :get, class: "flex-1 max-w-xl" do |f| %>
          <%= f.hidden_field :tab, value: params[:tab] || "collection" %>
          <div class="flex gap-2">
            <%= f.text_field :search,
                value: params[:search],
                placeholder: "Search kits...",
                class: "flex-1 bg-[#251f33] border border-[#2d2640] rounded-lg px-4 py-2 text-[#f0e6ff] placeholder-[#9d8faa] focus:outline-none focus:border-[#e879a0] transition-colors" %>
            <%= f.submit "Search",
                class: "bg-[#e879a0] hover:bg-[#f0a0c0] text-white font-medium px-4 py-2 rounded-lg transition-colors cursor-pointer shrink-0" %>
          </div>
        <% end %>

        <%# Tab navigation %>
        <nav class="flex gap-1 shrink-0">
          <%= link_to "Collection",
              collection_path,
              data: { turbo_action: "advance", turbo_frame: "_top" },
              class: "px-4 py-2 rounded-lg text-sm font-medium transition-colors #{(params[:tab] || 'collection') == 'collection' ? 'bg-[#e879a0] text-white' : 'text-[#9d8faa] hover:text-[#f0e6ff] hover:bg-[#251f33]'}" %>
          <%= link_to "Wishlist",
              wishlist_path,
              data: { turbo_action: "advance", turbo_frame: "_top" },
              class: "px-4 py-2 rounded-lg text-sm font-medium transition-colors #{params[:tab] == 'wishlist' ? 'bg-[#e879a0] text-white' : 'text-[#9d8faa] hover:text-[#f0e6ff] hover:bg-[#251f33]'}" %>
          <%= link_to "🎲 Pick",
              pick_path,
              class: "px-4 py-2 rounded-lg text-sm font-medium transition-colors text-[#9d8faa] hover:text-[#f0e6ff] hover:bg-[#251f33]" %>
        </nav>

      </div>
    </header>

    <%# Page content %>
    <main class="max-w-7xl mx-auto px-6 py-6">
      <%= yield %>
    </main>

  </body>
</html>